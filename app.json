{
	"expo": {
		"name": "OmniRing",
		"slug": "OmniRing",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./src/assets/images/icon.png",
		"scheme": "omniring",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "com.opencirqt.omniring.app"
		},
		"android": {
			"adaptiveIcon": {
				"foregroundImage": "./src/assets/images/adaptive-icon.png",
				"backgroundColor": "#ffffff"
			},
			"edgeToEdgeEnabled": true,
			"permissions": [
				"android.permission.FOREGROUND_SERVICE",
				"android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE",
				"android.permission.BLUETOOTH",
				"android.permission.BLUETOOTH_ADMIN",
				"android.permission.BLUETOOTH_CONNECT",
        "android.permissions.ACCESS_FINE_LOCATION"
			],
			"package": "com.opencirqt.omniring.app"
		},
		"web": {
			"bundler": "metro",
			"output": "static",
			"favicon": "./src/assets/images/favicon.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-splash-screen",
				{
					"image": "./src/assets/images/splash-icon.png",
					"imageWidth": 200,
					"resizeMode": "contain",
					"backgroundColor": "#f4fbfc"
				}
			],
			[
				"expo-build-properties",
				{
					"ios": {
						"deploymentTarget": "15.5"
					}
				}
			],
			[
				"expo-document-picker",
				{
					"iCloudContainerEnvironment": "Production"
				}
			],
			[
				"react-native-ble-manager",
				{
					"bluetoothAlwaysPermission": "App requires Bluetooth access to connect to the OmniRing device.",
					"isBleRequired": true,
					"neverForLocation": true
				}
			]
		],
		"experiments": {
			"typedRoutes": true
		}
	}
}
